# Convex Deployment Configuration
# Get this from your Convex project settings after running `npx convex dev`
VITE_CONVEX_URL=your_convex_deployment_http_url

# OAuth Secrets (Set these in your Convex Dashboard under Settings > Environment Variables)
# AUTH_GITHUB_ID=your_github_client_id
# AUTH_GITHUB_SECRET=your_github_client_secret
# AUTH_GOOGLE_ID=your_google_client_id
# AUTH_GOOGLE_SECRET=your_google_client_secret
